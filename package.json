{
  "name": "vibemaestro",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first project management dashboard for local single-user use",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "tokens": "bun run scripts/generate-tokens.ts",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:build": "bun run --cwd apps/desktop build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.1",
    "@types/node": "22.10.2",
    "turbo": "2.9.12",
    "typescript": "5.7.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "node-pty"
  ]
}
